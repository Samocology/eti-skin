{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "etiskin",
  "main": "dist/server/server.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "etiskin.godstimesml.workers.dev",
      "custom_domain": true
    }
  ]
}
